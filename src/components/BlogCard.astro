---
interface Props {
  title: string;
  description: string;
  pubDate: Date;
  slug: string;
  category?: string;
  tags?: string[];
  image?: string;
}

const { title, description, pubDate, slug, category, tags = [], image } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('cs-CZ', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="blog-card">
  {image && (
    <a href={`/blog/${slug}/`} tabindex="-1" aria-hidden="true">
      <img
        src={image}
        alt={title}
        class="blog-card-image"
        loading="lazy"
        width="800"
        height="450"
      />
    </a>
  )}
  <div class="blog-card-body">
    {category && (
      <a href={`/blog/kategorie/${category}/`} class="tag-category blog-card-category">
        {category}
      </a>
    )}
    <h2 class="blog-card-title">
      <a href={`/blog/${slug}/`}>{title}</a>
    </h2>
    <time class="blog-card-date" datetime={pubDate.toISOString()}>
      {formattedDate}
    </time>
    {description && <p class="blog-card-excerpt">{description}</p>}
    {tags.length > 0 && (
      <div class="blog-card-tags">
        {tags.map(tag => <span class="tag-format">{tag}</span>)}
      </div>
    )}
  </div>
</article>

<style>
  .blog-card {
    border-bottom: 1px solid var(--color-border);
    padding-bottom: var(--space-lg);
    margin-bottom: var(--space-lg);
  }

  .blog-card:last-child {
    border-bottom: none;
  }

  .blog-card-image {
    width: 100%;
    height: 220px;
    object-fit: cover;
    margin-bottom: var(--space-sm);
  }

  .blog-card-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .blog-card-category {
    margin-bottom: 2px;
  }

  .blog-card-title {
    font-size: var(--text-2xl);
    font-family: var(--font-heading);
    font-weight: 400;
    line-height: 1.3;
    margin: 0;
  }

  .blog-card-title a {
    color: var(--color-text);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .blog-card-title a:hover {
    color: var(--color-accent);
  }

  .blog-card-date {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .blog-card-excerpt {
    color: var(--color-text);
    line-height: 1.6;
    margin: 0;
  }

  .blog-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }
</style>
