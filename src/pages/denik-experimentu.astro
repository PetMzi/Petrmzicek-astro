---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const allPosts = await getCollection('blog', ({ data }) =>
  !data.draft && data.category === 'Deník experimentu'
);
const posts = allPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const renderedPosts = await Promise.all(
  posts.map(async (post) => {
    const { Content } = await render(post);
    return { post, Content };
  })
);
---

<BaseLayout
  title="Deník Experimentu"
  description="Jak AI pracuje s mými poznámkami. Deník mé cesty s AI, která mi pomáhá hledat nové souvislosti v tom, o čem přemýšlím."
>
  <div class="denik-page">
    <div class="container--text denik-intro">
      <h1 class="denik-title">DENÍK EXPERIMENTU</h1>
      <p class="denik-subtitle">Jak AI pracuje s mými poznámkami</p>
      <div class="denik-perex">
        <p>Je to deník mé cesty s AI, která mi pomáhá hledat nové souvislosti v tom, o čem přemýšlím.</p>
        <p>Každý zápisek vzniká automaticky.</p>
        <p><em>Píše Claude. Žije Petr.</em></p>
      </div>
      <hr class="denik-divider" />
    </div>
    <div class="container denik-list">
      {renderedPosts.map(({ post, Content }) => {
        const formattedDate = post.data.pubDate.toLocaleDateString('cs-CZ', {
          year: 'numeric',
          month: 'long',
          day: 'numeric',
        });
        return (
          <article class="denik-entry">
            <header class="denik-entry-header">
              <h2 class="denik-entry-title">
                <a href={`/blog/${post.id}/`}>{post.data.title}</a>
              </h2>
              <time class="denik-entry-date" datetime={post.data.pubDate.toISOString()}>
                {formattedDate}
              </time>
            </header>
            <div class="denik-entry-content">
              <Content />
            </div>
          </article>
        );
      })}
    </div>
  </div>
</BaseLayout>

<style>
  .denik-intro {
    padding-top: var(--space-xl);
    text-align: center;
  }

  .denik-title {
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    font-weight: 400;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-xs);
  }

  .denik-subtitle {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    margin-bottom: var(--space-lg);
  }

  .denik-perex {
    max-width: 560px;
    margin: 0 auto var(--space-lg);
    color: var(--color-text);
    line-height: 1.8;
  }

  .denik-perex p {
    margin-bottom: var(--space-xs);
  }

  .denik-divider {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: var(--space-lg) 0;
  }

  .denik-list {
    max-width: 720px;
    margin: 0 auto;
    padding-bottom: var(--space-2xl);
  }

  .denik-entry {
    border-bottom: 1px solid var(--color-border);
    padding-bottom: var(--space-lg);
    margin-bottom: var(--space-lg);
  }

  .denik-entry:last-child {
    border-bottom: none;
  }

  .denik-entry-header {
    margin-bottom: var(--space-sm);
  }

  .denik-entry-title {
    font-size: var(--text-2xl);
    font-family: var(--font-heading);
    font-weight: 400;
    line-height: 1.3;
    margin: 0 0 var(--space-xs);
  }

  .denik-entry-title a {
    color: var(--color-text);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .denik-entry-title a:hover {
    color: var(--color-accent);
  }

  .denik-entry-date {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .denik-entry-content {
    line-height: 1.8;
    color: var(--color-text);
  }

  .denik-entry-content p {
    margin-bottom: var(--space-sm);
  }

  .denik-entry-content p:last-child {
    margin-bottom: 0;
  }
</style>
