---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import BlogCard from '../components/BlogCard.astro';

const allPosts = await getCollection('blog', ({ data }) =>
  !data.draft && data.category === 'Deník experimentu'
);
const posts = allPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout
  title="Deník Experimentu"
  description="Jak AI pracuje s mými poznámkami. Deník mé cesty s AI, která mi pomáhá hledat nové souvislosti v tom, o čem přemýšlím."
>
  <div class="denik-page">
    <div class="container--text denik-intro">
      <h1 class="denik-title">DENÍK EXPERIMENTU</h1>
      <p class="denik-subtitle">Jak AI pracuje s mými poznámkami</p>
      <div class="denik-perex">
        <p>Je to deník mé cesty s AI, která mi pomáhá hledat nové souvislosti v tom, o čem přemýšlím.</p>
        <p>Každý zápisek vzniká automaticky.</p>
        <p><em>Píše Claude. Žije Petr.</em></p>
      </div>
      <hr class="denik-divider" />
    </div>
    <div class="container denik-list">
      {posts.map(post => (
        <BlogCard
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          slug={post.id}
          category={post.data.category}
          tags={post.data.tags}
          image={post.data.image}
        />
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .denik-intro {
    padding-top: var(--space-xl);
    text-align: center;
  }

  .denik-title {
    font-family: var(--font-heading);
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    font-weight: 400;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-xs);
  }

  .denik-subtitle {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    margin-bottom: var(--space-lg);
  }

  .denik-perex {
    max-width: 560px;
    margin: 0 auto var(--space-lg);
    color: var(--color-text);
    line-height: 1.8;
  }

  .denik-perex p {
    margin-bottom: var(--space-xs);
  }

  .denik-divider {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: var(--space-lg) 0;
  }

  .denik-list {
    max-width: 720px;
    margin: 0 auto;
    padding-bottom: var(--space-2xl);
  }
</style>
