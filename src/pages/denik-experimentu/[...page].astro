---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths({ paginate }) {
  const allPosts = await getCollection('blog', ({ data }) =>
    !data.draft && data.category === 'Deník experimentu'
  );
  const posts = allPosts.sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
  );
  return paginate(posts, { pageSize: 6 });
}

const { page } = Astro.props;

const renderedPosts = await Promise.all(
  page.data.map(async (post) => {
    const { Content } = await render(post);
    return { post, Content };
  })
);
---

<BaseLayout
  title={page.currentPage === 1 ? 'Deník Experimentu' : `Deník Experimentu – strana ${page.currentPage}`}
  description="Jak AI pracuje s mými poznámkami. Deník mé cesty s AI, která mi pomáhá hledat nové souvislosti v tom, o čem přemýšlím."
>
  <div class="page-wrapper">
    <div class="content-container">

      <div class="hero-section">
        <h1 class="page-title">Deník Experimentu</h1>
        <p>Jak AI pracuje s mými poznámkami</p>
        <p>Je to deník mé cesty s AI, která mi pomáhá hledat nové souvislosti v tom, o čem přemýšlím.</p>
        <p>Každý zápisek vzniká automaticky.</p>
        <p><em>Píše Claude. Žije Petr.</em></p>
      </div>

      <div class="posts-list">
        {renderedPosts.map(({ post, Content }) => {
          const formattedDate = post.data.pubDate.toLocaleDateString('cs-CZ', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          });
          return (
            <article>
              <time class="post-date" datetime={post.data.pubDate.toISOString()}>
                {formattedDate}
              </time>
              <h2 class="post-title">{post.data.title}</h2>
              <div class="post-content">
                <Content />
              </div>
              <hr class="post-separator" />
            </article>
          );
        })}
      </div>

      {page.lastPage > 1 && (
        <nav class="pagination" aria-label="Stránkování">
          {Array.from({ length: page.lastPage }, (_, i) => i + 1).map((num) =>
            num === page.currentPage ? (
              <span class="current">{num}</span>
            ) : (
              <a href={num === 1 ? '/denik-experimentu/' : `/denik-experimentu/${num}/`}>{num}</a>
            )
          )}
          {page.url.next && (
            <a href={page.url.next} class="pagination-next">Starší →</a>
          )}
        </nav>
      )}

    </div>
  </div>
</BaseLayout>

<style>
  .page-wrapper {
    padding: 2em;
  }

  .content-container {
    max-width: 960px;
    margin-left: auto;
    margin-right: auto;
  }

  .hero-section {
    max-width: 960px;
    padding-top: 24px;
    padding-bottom: 0px;
  }

  h1.page-title {
    font-family: Lora, serif;
    font-weight: 600;
    font-size: 36px;
    color: #2c3e50;
    text-align: center;
    margin-bottom: -2px;
  }

  .hero-section p {
    text-align: center;
    font-family: Montserrat, sans-serif;
    font-size: 18px;
    color: #2c3e50;
    margin-bottom: 1.5em;
  }

  .posts-list {
    margin-top: 80px;
  }

  .post-date {
    display: block;
    font-family: Montserrat, sans-serif;
    font-size: 0.8em;
    font-weight: 400;
    color: #575760;
    margin-bottom: 0.25em;
  }

  h2.post-title {
    font-family: Lora, serif;
    font-weight: 600;
    font-size: 28px;
    line-height: 1.2em;
    color: #2c3e50;
    margin-bottom: 1em;
  }

  h2.post-title a {
    color: #222222;
    text-decoration: none;
  }

  h2.post-title a:hover {
    color: #575760;
  }

  .post-content p {
    font-family: Montserrat, sans-serif;
    font-size: 18px;
    line-height: 1.7;
    color: #2c3e50;
    margin-bottom: 1.5em;
  }

  hr.post-separator {
    border: none;
    border-top: 2px solid #e9e6e1;
    margin: 2em 0;
    opacity: 1;
  }

  .pagination {
    display: flex;
    justify-content: center;
    gap: 0.5em;
    margin-top: 2em;
    font-family: Montserrat, sans-serif;
    font-size: 16px;
  }

  .pagination a,
  .pagination .current {
    color: #2c3e50;
    text-decoration: none;
  }

  .pagination .current {
    font-weight: 700;
    color: #c0966b;
  }

  .pagination a:hover {
    color: #c0966b;
  }

  .pagination-next {
    font-family: Montserrat, sans-serif;
    font-weight: 600;
    color: #c0966b;
    text-decoration: none;
    margin-left: 1em;
  }

  .pagination-next:hover {
    text-decoration: underline;
  }

  @media (max-width: 768px) {
    .page-wrapper {
      padding: 30px;
    }

    h1.page-title {
      font-size: 28px;
    }

    h2.post-title {
      font-size: 22px;
    }
  }
</style>
