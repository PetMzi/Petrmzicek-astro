---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Petr Mžíček – kouč vědomé produktivity"
  description="Pomáhám lidem, kteří potřebují skloubit své sny s hypotékou. Vědomá produktivita, koučink, záměr."
>
  <section class="hero">
    <div class="container">
      <div class="hero-inner">
        <div class="hero-text">
          <h1>Nejlepší způsob života žijeme podle sebe</h1>
          <p class="hero-sub">Nejdřív se ale musíme naučit říct „ne".</p>
          <p class="hero-desc">Pomáhám lidem, kteří potřebují skloubit své sny s hypotékou.</p>
        </div>
        <div class="hero-photo">
          <img
            src="https://petrmzicek.cz/wp-content/uploads/2025/10/Profil1-4.jpg"
            alt="Petr Mžíček"
            width="560"
            height="760"
            loading="eager"
            fetchpriority="high"
          />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    background-color: #fdfdfa;
    padding: 64px 0;
  }

  .container {
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }

  .hero-text h1 {
    font-family: 'Lora', serif;
    font-size: 36px;
    font-weight: 600;
    color: #2c3e50;
    line-height: 1.2;
    margin: 0 0 16px;
  }

  .hero-sub {
    font-family: 'Montserrat', sans-serif;
    font-size: 18px;
    font-weight: 400;
    color: #575760;
    margin: 0 0 24px;
  }

  .hero-desc {
    font-family: 'Montserrat', sans-serif;
    font-size: 18px;
    font-weight: 400;
    line-height: 1.7;
    color: #2c3e50;
    margin: 0;
  }

  .hero-photo img {
    width: 100%;
    height: auto;
    max-width: 560px;
    display: block;
    margin-left: auto;
  }

  @media (max-width: 768px) {
    .hero-inner {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .hero-photo {
      order: 2;
    }

    .hero-text {
      order: 1;
    }

    .hero-photo img {
      max-width: 100%;
      margin: 0 auto;
    }
  }
</style>
